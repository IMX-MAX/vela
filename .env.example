# --- Public (exposed to the browser) ---
# Your Appwrite project ID and API endpoint.
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=Vela

# --- Server-only secrets (NEVER expose to the client / commit real values) ---
# Mistral API key used by the AI server actions.
MISTRAL_API_KEY=

# Appwrite server API key. Only used by the one-off setup_appwrite.mjs script.
APPWRITE_API_KEY=

# --- Stripe ---
# Publishable key for the Stripe.js frontend SDK.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key for server-side Stripe API calls.
STRIPE_SECRET_KEY=

# Webhook signing secret for verifying Stripe webhook events.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the Pro plan.
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=
